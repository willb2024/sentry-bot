// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String   @id @default(uuid())
  telegramId          String   @unique
  username            String?
  
  autoSnipeConfig     AutoSnipeConfig?
  
  activeWallets       Int      @default(1)
  vault2              String?  @unique
  pk2                 String?  @unique
  vault3              String?  @unique
  pk3                 String?  @unique
  vault4              String?  @unique
  pk4                 String?  @unique
  vault5              String?  @unique
  pk5                 String?  @unique

  priorityLevel       String   @default("FAST") // "ECO" | "FAST" | "TURBO" | "CUSTOM"
  customPriorityFee   Float    @default(0.001) // In SOL

  ownedGuild       Guild?            @relation("GuildOwner")
  guildMemberships GuildMembership[] @relation("GuildMemberships")

  vaultAddress        String?  @unique
  turnkeySubOrgId     String?  @unique

  referralCode        String   @unique
  referredById        String?  
  referredBy          User?    @relation("AffiliateTree", fields: [referredById], references: [id])
  recruits            User[]   @relation("AffiliateTree")

  totalVolumeSol      Float    @default(0.0) 
  isLoyaltyUnlocked   Boolean  @default(false) 
  hasReferralDiscount Boolean  @default(false) 
  
  slippagePercent     Float    @default(20.0)

  pendingRewardsSol   Float    @default(0.0) 
  
  isVip               Boolean   @default(false)
  vipTier             String?
  vipExpiresAt        DateTime? 
  vipSource           String?   
  vipTxSignature      String?
  vipPurchasedAt      DateTime?

  isDevSuiteUnlocked  Boolean  @default(false)

  trades              Trade[]
  activeOrders        ActiveOrder[] 
  copyTrades          CopyTradeConfig[] 
  launchedTokens      LaunchedToken[] // 🟢 NEW: Tracks user's launches

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([telegramId])
  @@index([referralCode])
}

// 🟢 NEW: Launch Portfolio Model
model LaunchedToken {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields:[userId], references: [id])
  
  tokenAddress      String   @unique
  name              String
  symbol            String
  
  launchedAt        DateTime @default(now())
  devBuySol         Float
  walletCount       Int
  
  totalVolumeBumped Float    @default(0.0)
  isActive          Boolean  @default(true)
  
  @@index([userId])
}

model Trade {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields:[userId], references: [id])

  tokenAddress    String
  isBuy           Boolean
  amountInSol     Float

  feeChargedSol   Float    
  affiliateCutSol Float    
  loyaltyRebateSol Float   

  txSignature     String   
  status          String   @default("CONFIRMED") 

  profitPercent   Float?   @default(0)
  realizedPnlSol  Float?   @default(0)

  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([tokenAddress])
  @@index([txSignature])  
}

model ActiveOrder {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields:[userId], references: [id])

  tokenAddress      String
  orderType         String 

  amountSol         Float
  targetPriceUsd    Float?   
  trailingPercent   Float?   
  takeProfitPercent Float?   
  dcaIntervalMins   Int?     
  
  maxBudgetSol      Float?   
  totalSpentSol     Float    @default(0.0)

  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId, isActive])
  @@index([tokenAddress])
}

model AutoSnipeConfig {
  id                      String   @id @default(uuid())
  userId                  String   @unique
  user                    User     @relation(fields: [userId], references: [id])
  
  isActive                Boolean  @default(false)
  sniperMode              String   @default("PUMP") 
  amountSol               Float    @default(0.05)
  
  requireSocials          Boolean  @default(true)
  maxDevBuyPercent        Float    @default(10.0)
  
  autoTrailingDropPercent Float    @default(20.0) 
  autoTakeProfitPercent   Float?

  minMarketCap            Float    @default(0.0)
  maxMarketCap            Float    @default(100000.0)
  antiDeadCoin            Boolean  @default(false)

  maxBudgetSol            Float?   
  totalSpentSol           Float    @default(0.0)

  snipeDelaySeconds       Int      @default(0) 

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model CopyTradeConfig {
  id                      String   @id @default(uuid())
  userId                  String   
  user                    User     @relation(fields: [userId], references: [id])
  
  targetWallet            String   
  tradeAmountSol          Float    @default(0.1) 
  
  autoTrailingDropPercent Float    @default(20.0) 
  autoTakeProfitPercent   Float?                  
  
  isActive                Boolean  @default(true)
  
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([targetWallet])
  @@index([userId])
}

model Guild {
  id               String            @id @default(uuid())
  ownerId          String            @unique          
  owner            User              @relation("GuildOwner", fields: [ownerId], references: [id])

  guildCode        String            @unique          
  name             String                             
  description      String?                            
  rewardDescription String?                           

  feePaidSol       Float             @default(2.0)
  isActive         Boolean           @default(true)

  members          GuildMembership[]

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([guildCode])
}

model GuildMembership {
  id               String            @id @default(uuid())
  guildId          String
  guild            Guild             @relation(fields: [guildId], references: [id])
  userId           String
  user             User              @relation("GuildMemberships", fields: [userId], references: [id])

  loyaltyPoints    Float             @default(0.0)   
  totalVolumeSol   Float             @default(0.0)   
  rank             Int?                            
  airdropsReceivedSol Float          @default(0.0)

  isActive         Boolean           @default(true) 

  joinedAt         DateTime          @default(now())
  lastActiveAt     DateTime          @default(now())

  @@unique([guildId, userId])               
  @@index([guildId, loyaltyPoints])
}

model DailyVipPromo {
  id          String   @id @default(uuid())
  date        String   @unique  
  slotsUsed   Int      @default(0)
  maxSlots    Int      @default(10)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}